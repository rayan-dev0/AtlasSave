{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AtlasSave",
  "version": "0.2.0",
  "identifier": "com.atlassave.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AtlasSave",
        "width": 960,
        "height": 640,
        "minWidth": 900,
        "minHeight": 580,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW51c2VkX21vY2tfcHVia2V5X3BsYWNlaG9sZGVyX2Zvcl9kZXZlbG9wbWVudAo=",
      "endpoints": [
        "https://raw.githubusercontent.com/rayan-dev0/AtlasSave/main/updater-manifest.json"
      ]
    }
  }
}
